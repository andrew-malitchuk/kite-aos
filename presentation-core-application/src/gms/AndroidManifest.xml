<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools">
    <!--
        GeckoView declares minSdk 26 in its own manifest, but the gms flavor
        uses only the standard Android WebView (AndroidWebViewEngine) and never
        instantiates GeckoViewEngine. The override suppresses the manifest-merger
        error so gms can target API 25 without runtime risk.
    -->
    <uses-sdk tools:overrideLibrary="org.mozilla.geckoview,org.mozilla.geckoview.thirdparty" />
</manifest>
